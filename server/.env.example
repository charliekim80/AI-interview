# TecAce AI Interview Server - 환경변수 설정
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요
# cp .env.example .env

# 서버 포트 (기본값: 3000)
PORT=3000

# 클라이언트 URL (CORS 허용)
CLIENT_URL=http://localhost:5173

# OpenAI API Key (Admin Settings 페이지에서도 설정 가능, 없으면 Mock 모드로 동작)
OPENAI_API_KEY=

# DB 파일 경로 (기본값: 자동 설정됨)
# DB_PATH=./db/database.sqlite
